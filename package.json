{
  "name": "fakerpress",
  "title": "FakerPress",
  "version": "0.9.0",
  "homepage": "https://fakerpress.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/bordoni/fakerpress.git"
  },
  "scripts": {
    "lint:js": "wp-scripts lint-js src/ --ignore-pattern src/resources/js/qs.js --ignore-pattern src/resources/js/select2.js",
    "lint:css": "wp-scripts lint-style",
    "lint:php": "vendor/bin/phpcs --extensions=php",
    "lint:php:fix": "vendor/bin/phpcbf --extensions=php",
    "lint": "bun run lint:js && bun run lint:css",
    "format:css": "wp-scripts lint-style --fix",
    "format:js": "wp-scripts lint-js src/ --ignore-pattern src/resources/js/qs.js --ignore-pattern src/resources/js/select2.js --fix",
    "build": "wp-scripts build",
    "start": "wp-scripts start --mode=development --devtool=source-map",
    "test": "wp-scripts test-unit-js",
    "test:watch": "wp-scripts test-unit-js --watch"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFiles": [
      "<rootDir>/src/resources/packages/admin/__mocks__/wordpress.ts"
    ],
    "moduleNameMapper": {
      "^@wordpress/api-fetch$": "<rootDir>/src/resources/packages/admin/__mocks__/@wordpress/api-fetch.ts",
      "^@wordpress/i18n$": "<rootDir>/src/resources/packages/admin/__mocks__/@wordpress/i18n.ts",
      "^@fp/(.*)$": "<rootDir>/src/resources/packages/$1",
      "\\.(css|pcss)$": "<rootDir>/src/resources/packages/admin/__mocks__/styleMock.ts"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/build/",
      "/vendor/"
    ]
  },
  "main": "Gruntfile.js",
  "devDependencies": {
    "@stellarwp/tyson": "^0.0.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@wordpress/scripts": "^30.16.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.576.0",
    "postcss-import": "^16.1.0",
    "postcss-mixins": "^11.0.3",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^10.1.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "zod": "^4.3.6"
  }
}
