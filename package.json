{
  "name": "fakerpress",
  "title": "FakerPress",
  "version": "0.9.0",
  "homepage": "https://fakerpress.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/bordoni/fakerpress.git"
  },
  "scripts": {
    "lint:js": "wp-scripts lint-js src/ --ignore-pattern src/resources/js/qs.js --ignore-pattern src/resources/js/select2.js",
    "lint:css": "wp-scripts lint-style",
    "lint:php": "vendor/bin/phpcs --extensions=php",
    "lint:php:fix": "vendor/bin/phpcbf --extensions=php",
    "lint": "npm run lint:js && npm run lint:css",
    "format:css": "wp-scripts lint-style --fix",
    "format:js": "wp-scripts lint-js src/ --ignore-pattern src/resources/js/qs.js --ignore-pattern src/resources/js/select2.js --fix",
    "build": "wp-scripts build",
    "start": "wp-scripts start --mode=development --devtool=source-map"
  },
  "main": "Gruntfile.js",
  "devDependencies": {
    "@stellarwp/tyson": "^0.0.7",
    "@wordpress/scripts": "^31.6.0",
    "postcss-import": "^16.1.0",
    "postcss-mixins": "^11.0.3",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^10.1.5"
  },
  "engines": {
    "node": "18.17.0",
    "npm": "9.6.7"
  },
  "dependencies": {}
}
